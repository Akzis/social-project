{
  "kind": "collectionType",
  "collectionName": "volunteer_profiles",
  "info": {
    "singularName": "volunteer-profile",
    "pluralName": "volunteer-profiles",
    "displayName": "volunteer-profile"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "authUserId": {
      "type": "integer",
      "unique": true
    },
    "provider": {
      "type": "enumeration",
      "enum": [
        "local",
        "yandex",
        "other"
      ],
      "default": "local"
    },
    "providerUserId": {
      "type": "string",
      "unique": true
    },
    "providerLogin": {
      "type": "string"
    },
    "registrationMode": {
      "type": "enumeration",
      "enum": [
        "volunteer"
      ],
      "default": "volunteer"
    },
    "name": {
      "type": "string"
    },
    "firstName": {
      "type": "string"
    },
    "lastName": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "emailDisplay": {
      "type": "email"
    },
    "displayName": {
      "type": "string"
    },
    "avatarUrl": {
      "type": "string"
    },
    "emailVerified": {
      "type": "boolean",
      "default": false
    },
    "lastLoginAt": {
      "type": "datetime"
    },
    "interest": {
      "type": "text"
    },
    "gosuslugiVerified": {
      "type": "boolean",
      "default": false
    },
    "soundEnabled": {
      "type": "boolean",
      "default": true
    },
    "deedsCount": {
      "type": "integer",
      "default": 0
    },
    "totalHours": {
      "type": "decimal",
      "default": 0
    },
    "peopleNeedHelp": {
      "type": "integer",
      "default": 500
    },
    "quoteText": {
      "type": "text"
    },
    "volunteer_achievement_progresses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::volunteer-achievement-progress.volunteer-achievement-progress",
      "mappedBy": "volunteer_profile"
    },
    "review_valonteers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review-valonteer.review-valonteer",
      "mappedBy": "volunteer_profile"
    }
  }
}
